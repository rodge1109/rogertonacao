<script>/* ===== Match card cycler — true two-face flip ===== */
(function() {
  var matches = [
    { role: 'Earnings Analysis Trainer',    rate: '$70–90 / hr',  tags: ['Financial AI', 'CFA or MBA', 'Remote'] },
    { role: 'Investment Research Reviewer', rate: '$80–100 / hr', tags: ['Financial AI', 'Finance degree', 'Remote'] },
    { role: 'Financial Model Validator',    rate: '$75–95 / hr',  tags: ['Financial AI', 'Excel / Python', 'Remote'] },
  ];
  var idx = 0;           // index currently visible
  var flipped = false;   // false = front visible, true = back visible

  var wrap  = document.getElementById('hmcWrap');
  var front = document.getElementById('hmcFront');
  var back  = document.getElementById('hmcBack');
  if (!wrap || !front || !back) return;

  function renderFace(face, match) {
    face.innerHTML =
      '<div class="hmc-badge"><span class="dot"></span> New match</div>' +
      '<div class="hmc-role">' + match.role + '</div>' +
      '<div class="hmc-rate">' + match.rate + '</div>' +
      '<div class="hmc-tags">' + match.tags.map(function(t){ return '<span class="hmc-tag">' + t + '</span>'; }).join('') + '</div>';
  }

  // Back face is pre-loaded in HTML with match[1] — keep in sync with idx=1
  var preloaded = 1;

  function nextMatch() {
    var nextIdx = (idx + 1) % matches.length;
    var afterIdx = (nextIdx + 1) % matches.length;

    // The hidden face should already have nextIdx loaded — flip to reveal it
    flipped = !flipped;
    wrap.classList.toggle('flipped', flipped);
    idx = nextIdx;

    // After the transition completes (650ms), load afterIdx into the now-hidden face
    setTimeout(function() {
      var hiddenFace = flipped ? front : back;
      renderFace(hiddenFace, matches[afterIdx]);
    }, 700);
  }

  setInterval(nextMatch, 3500);
})();

// Scroll fade-in for How It Works steps
(function() {
  var steps = document.querySelectorAll('.step');
  if (!steps.length) return;
  if (!('IntersectionObserver' in window)) {
    steps.forEach(function(s) { s.classList.add('visible'); });
    return;
  }
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        var el = entry.target;
        var delay = parseInt(el.dataset.delay || 0);
        setTimeout(function() { el.classList.add('visible'); }, delay);
        obs.unobserve(el);
      }
    });
  }, { threshold: 0.15 });
  steps.forEach(function(s, i) {
    s.dataset.delay = i * 110;
    obs.observe(s);
  });
})();

