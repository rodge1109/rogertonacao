<style>:root {
  /* ── Semantic color tokens (light values). Components reference THESE, never raw hex,
   * so .theme-dark can flip the whole system by re-defining the same names. ── */
  --ink:   #0A0A0A;          /* primary text */
  --ink-2: #2A2A2A;          /* secondary text */
  --ink-3: #5C6F69;          /* muted text */
  --bg:      #ffffff;        /* page background */
  --surface: #ffffff;        /* card / panel background */
  --surface-2: #FAFAF6;      /* soft / inset surface (inputs, upload, chips) */
  --bg-soft: #FAFAF6;        /* legacy alias of --surface-2 — keep for existing rules */
  --line:    rgba(10, 10, 10, 0.08);  /* hairline borders */
  --line-2:  rgba(10, 10, 10, 0.14);  /* stronger borders (inputs, dashed) */
  --accent:  #0A8C66;        /* eyebrows / links on the current surface (green on light) */
  --btn-bg:  #0A0A0A;        /* inverted/primary button: ink fill on light… */
  --btn-fg:  #ffffff;        /* …white label. Flips in dark so it stays high-contrast. */
  --btn-bg-hover: #1a1a1a;
  --shadow-card: 0 1px 2px rgba(15,30,26,0.04), 0 8px 28px rgba(15,30,26,0.08);

  /* Iridescent palette */
  --iri-cyan:  #5BCFFF;
  --iri-green: #4FE8A9;
  --iri-lime:  #D5FF66;

  /* Brand purple */
  --purple:        #5B4FCF;
  --purple-light:  #EEEBFF;
  --purple-bright: #7B00FF; /* top-alert bar */

  /* Brand greens */
  --green:     #0A8C66;
  --green-mid: #4FE8A9;

  /* Border-radius scale */
  --r-sm:   8px;
  --r-md:   12px;
  --r-lg:   16px;
  --r-xl:   20px;
  --r-2xl:  28px;
  --r-pill: 999px;

  /* ── Layout widths ── (the outer shell is a touch wider than content, so the
   * nav/footer sit just outside the section content — the PTF house pattern.
   * These are the original, proven defaults; existing pages render unchanged.) */
  --container:     1400px;  /* OUTER SHELL only: nav + footer edges. Body content sits INSIDE this (never as wide as the bar). */
  --content-body:  1200px;  /* DEFAULT body-section width — the widest content sits here, inset from the 1400 shell */
  --content-wide:  1180px;  /* .section-narrow — narrower content blocks, inside the shell */
  --content:       1080px;  /* a comfortable content column */
  --content-narrow: 720px;  /* centered headline / prose / form cards */
  --gutter:          32px;  /* left/right page padding */

  /* ── Vertical rhythm ── THE spacing model. ONE token, applied as a section's TOP and
   * BOTTOM padding. Two adjacent sections stack their halves → every gap = 2×--section-y,
   * identical everywhere. The gap is NEUTRAL (it's the section's own padding, not a colored
   * band — a colored block keeps its color on an inner element so the gap stays neutral).
   * Never hand-set section padding; use the token so it stays even. */
  --section-y:       100px; /* standard half-gap, top & bottom of every section */
  --section-y-tight:  80px; /* denser rhythm (one-line statements) */
  --section-y-loose: 140px; /* generous: hero / final-CTA closer */
  --hero-top:         56px; /* TOP padding of the first section under the nav (.section-hero) — tighter than --section-y because the sticky nav already adds breathing room */
}
/* One token drives mobile too — shrink it here and EVERY section follows (don't add
 * per-section mobile padding overrides; that's what broke the even rhythm before). */
@media (max-width: 768px) {
  :root { --section-y: 60px; --section-y-tight: 48px; --section-y-loose: 84px; --gutter: 20px; --hero-top: 32px; }
}


/* ===== Reset ===== */
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
body {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  color: var(--ink);
  background: var(--bg);
  font-size: 16px;
  line-height: 1.55;
}
img { display: block; max-width: 100%; }

/* ===== Typography ===== */
.display {
  font-family: 'Inter Tight', 'Inter', system-ui, sans-serif;
  font-weight: 700;
  letter-spacing: -0.035em;
  line-height: 1.0;
}

.italic-plain {
  font-family: 'Inter Tight', 'Inter', system-ui, sans-serif;
  font-style: italic;
  font-weight: 700;
  color: inherit; /* match the headline's ink — stays dark on light, white on dark sections (e.g. .section-cta) */
  letter-spacing: -0.025em;
}

/* ===== Eyebrow — the small green label above a headline =====
 * RULE: eyebrows and small category labels are PLAIN green uppercase text.
 * NEVER a pill / background / border-radius. This is the brand. */
.eyebrow {
  display: inline-flex; align-items: center; gap: 7px;
  font-family: 'Inter Tight', 'Inter', sans-serif;
  font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 16px;
}
.eyebrow .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); flex-shrink: 0; }
/* On dark backgrounds — still plain text, just the lighter green */
/* .eyebrow flips via --accent now; .eyebrow-on-dark stays for ad-hoc dark blocks on light pages */
.eyebrow-on-dark { color: var(--green-mid); }

/* ===== Buttons ===== */
.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 14px 26px; border-radius: 999px;
  font-family: 'Inter Tight', 'Inter', sans-serif;
  font-size: 15px; font-weight: 600;
  letter-spacing: -0.01em;
  text-decoration: none; cursor: pointer;
  border: 1.5px solid var(--ink);
  background: #ffffff; color: var(--ink);
  transition: transform 180ms ease, background 180ms ease, color 180ms ease, box-shadow 180ms ease;
}
.btn:hover { transform: translateY(-1px); background: var(--ink); color: #fff; }
.btn-primary { background: var(--ink); color: #fff; border-color: var(--ink); }
.btn-primary:hover {
  background: #1a1a1a; color: #fff;
  box-shadow: 0 12px 28px rgba(79,232,169,0.25), 0 4px 12px rgba(0,0,0,0.18);
}
.btn-sm { padding: 10px 18px; font-size: 14px; }
/* White button on dark backgrounds */
.btn-light {
  background: #ffffff; color: #0A0A0A; border-color: #ffffff;
}
.btn-light:hover {
  background: rgba(255,255,255,0.88); color: #0A0A0A;
  box-shadow: 0 12px 28px rgba(255,255,255,0.12), 0 4px 12px rgba(0,0,0,0.3);
  transform: translateY(-1px);
}

/* ===== Shared Animations ===== */
@keyframes marquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* ===== Page layout ===== */
.section { padding: 100px 32px; }
.section-narrow {
    max-width: var(--content-wide);
    margin: 0 auto;
}
.section-head { max-width: 720px; margin: 0 auto 56px; text-align: center; }
.section-head h2 {
  font-family: 'Inter Tight', 'Inter', sans-serif;
  font-weight: 700; font-size: clamp(32px, 4vw, 52px);
  line-height: 1.05; letter-spacing: -0.03em; color: var(--ink);
}
.section-head p {
  margin-top: 16px; font-size: 16.5px;
  color: var(--ink-3); line-height: 1.6;
  max-width: 48ch; margin-left: auto; margin-right: auto;
}

/* ===== Coming-soon pages ===== */
.cs-wrap {
  min-height: 80vh;
  display: flex; align-items: center; justify-content: center;
  padding: 80px 32px; text-align: center;
}
.cs-inner { max-width: 560px; margin: 0 auto; }
.cs-eyebrow {
  font-size: 12px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--green); margin-bottom: 20px;
}
.cs-headline {
  font-family: 'Inter Tight', sans-serif;
  font-size: clamp(36px, 5vw, 60px); font-weight: 800;
  letter-spacing: -0.04em; line-height: 1.0;
  color: var(--ink); margin-bottom: 20px;
}
.cs-sub { font-size: 18px; color: var(--ink-3); line-height: 1.6; margin-bottom: 40px; }
.cs-cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

/* ===== Testimonial cards ===== */
.testimonials {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 20px; margin-top: 48px;
}
.t-card {
  background: #fff; border: 1px solid var(--line);
  border-radius: var(--r-xl); padding: 24px;
  display: flex; flex-direction: column;
  transition: transform 200ms ease;
}
.t-card:hover { transform: translateY(-4px); }
.t-stars { color: #F5A623; font-size: 14px; letter-spacing: 2px; }
.t-quote {
  margin-top: 14px; font-size: 15px; line-height: 1.5;
  color: var(--ink); letter-spacing: -0.005em;
}
.t-meta {
  margin-top: auto; padding-top: 22px;
  display: flex; align-items: flex-end; justify-content: space-between; gap: 12px;
}
.t-meta-info { display: flex; flex-direction: column; min-width: 0; }
.t-author  { font-size: 14px; font-weight: 600; color: var(--ink); }
.t-company { font-size: 13.5px; font-weight: 500; color: var(--ink-2); margin-top: 4px; }
.t-role    { font-size: 12.5px; color: var(--ink-3); margin-top: 2px; line-height: 1.35; }
.t-li {
  display: inline-flex; align-items: center; gap: 4px;
  margin-top: 8px; text-decoration: none;
  font-size: 11.5px; font-weight: 600; color: #0A66C2;
  transition: opacity .15s;
}
.t-li:hover { opacity: 0.7; }
.t-li svg { width: 18px; height: 18px; fill: #0A66C2; flex-shrink: 0; }
.t-logo {
  width: 52px; height: 52px; border-radius: 50%;
  flex-shrink: 0; overflow: hidden;
  display: inline-flex; align-items: center; justify-content: center;
}
.t-logo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }

/* ===== Benefit cards ===== */
.benefit-card {
  border-radius: var(--r-xl);
  border: 1px solid rgba(10,10,10,0.09);
  box-shadow: var(--shadow-card);
  background: var(--bg);
  padding: 32px 28px 36px;
  display: flex; flex-direction: column; gap: 12px;
}
.benefit-sparkle {
  width: 52px; height: 52px;
  animation: floatY 4s ease-in-out infinite;
  margin-bottom: 4px;
}
.benefit-card:nth-child(2) .benefit-sparkle { animation-delay: -1.3s; }
.benefit-card:nth-child(3) .benefit-sparkle { animation-delay: -2.7s; }
.benefit-eyebrow {
  font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--green);
}
.benefit-card h3 {
  font-family: 'Inter Tight', sans-serif;
  font-size: 19px; font-weight: 700;
  letter-spacing: -0.03em; line-height: 1.2; color: var(--ink);
}
.benefit-card p { font-size: 15px; color: var(--ink-2); line-height: 1.6; }

  /* ===== Logo carousel / marquee — animated scrolling client logos =====
 * Markup: <div class="logo-strip"><div class="logo-strip-track" id="logos"></div></div>
 * then PTF.initMarquee('logos', ['<img src=... alt=...>', ...]) duplicates for a seamless loop. */
.logo-strip { overflow: hidden; -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent); mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent); }
.logo-strip-track { display: inline-flex; align-items: center; gap: 64px; white-space: nowrap; animation: marquee 40s linear infinite; will-change: transform; }
.logo-strip-track img { height: 30px; width: auto; opacity: 0.55; filter: grayscale(1); flex-shrink: 0; transition: opacity .2s; }
.logo-strip-track img:hover { opacity: 0.9; }

/* ===== Mission / statement section (one big centered statement line) =====
 * A single large centered sentence — the brand "why". Use <h2 class="mission-statement">
 * (a <p> works too). On a dark page the text flips white automatically. */
.section-mission { background: var(--bg); padding: var(--section-y-tight) var(--gutter); text-align: center; }  /* a one-line statement: tighter rhythm so it doesn't float */
.mission-statement { max-width: var(--content-wide); margin: 0 auto; font-family: 'Inter Tight', 'Inter', sans-serif; font-weight: 600; font-size: clamp(34px, 4.4vw, 60px); line-height: 1.22; letter-spacing: -0.022em; color: var(--ink); }
/* mission flips via --bg / --ink tokens — no override needed */

/* ===== Stats + portrait card ("stats + portrait with the P") =====
 * Two-up contained card: a tall portrait on the left, a dark stat stack on the right.
 * Shared by employers + talents. For a LIGHT portrait photo, invert the corner icon —
 * add the .stats-portrait--light modifier (see DESIGN-SYSTEM.md). */
.section-stats { background: var(--bg); padding: var(--section-y) var(--gutter); }
.stats-card-wrap { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1.15fr; gap: 8px; border-radius: 32px; }
.stats-portrait { border-radius: var(--r-2xl); overflow: hidden; background-size: cover; background-position: center; position: relative; }
.stats-portrait-icon { position: absolute; top: 20px; left: 20px; width: 52px; height: 52px; filter: drop-shadow(0 6px 16px rgba(0,0,0,0.28)); }
.stats-portrait--light .stats-portrait-icon { filter: brightness(0) invert(1) drop-shadow(0 4px 12px rgba(0,0,0,0.45)); }
.stats-card-dark { background: #0A0A0A; border-radius: var(--r-2xl); padding: 64px 56px; display: flex; flex-direction: column; justify-content: center; gap: 40px; color: #fff; }
.stat-big-num { font-family: 'Inter Tight', 'Inter', sans-serif; font-weight: 700; font-size: clamp(56px, 8vw, 104px); line-height: 1; letter-spacing: -0.04em; color: #fff; }
.stat-unit { font-size: 0.28em; font-weight: 700; letter-spacing: -0.02em; color: #fff; margin-left: 4px; vertical-align: baseline; }
.stat-big-label { margin-top: 10px; font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.58); letter-spacing: 0.01em; line-height: 1.45; }

/* ===== Final CTA band (dark) — was .section-book / .closing-cta ===== */
.section-cta { background: #000000; color: #fff; padding: var(--section-y-loose) var(--gutter); text-align: center;     border-bottom: 1px solid rgba(255, 255, 255, 0.12);}  /* loose rhythm (generous) + same black as the footer so the band blends into it */
.section-cta .section-cta-inner { max-width: 720px; margin: 0 auto; }
/* The CTA band ALWAYS opens with a green eyebrow. The band is dark, so any .eyebrow inside it
 * is auto-set to the bright green-mid (no need to remember .eyebrow-on-dark). Part of the component. */
.section-cta .eyebrow { color: var(--green-mid); }
.section-cta h2 {
  font-family: 'Inter Tight', 'Inter', sans-serif; font-weight: 800;
  font-size: clamp(36px, 5vw, 68px); letter-spacing: -0.04em; line-height: 0.98; color: #fff;
  margin-bottom: 20px;
}
.section-cta p { font-size: 18px; color: rgba(255,255,255,0.55); line-height: 1.6; margin: 0 auto 32px; max-width: 56ch; }

/* ===== How-it-works portrait (the tall photo that sits beside .steps) =====
 * Pair .how-inner (2-up grid) with a .how-portrait-card on one side and .steps on the other.
 * Set the photo via inline background-image; for a dark page, content may override to min-height. */
.how-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: stretch; }
/* height follows the steps beside it (fewer steps → shorter image, width unchanged) */
.how-portrait-card { border-radius: var(--r-2xl); overflow: hidden; background-size: cover; background-position: center; position: relative; }
.how-portrait-icon { position: absolute; top: 20px; left: 20px; width: 48px; height: 48px; filter: drop-shadow(0 4px 14px rgba(0,0,0,0.4)); }

/* ===== Alternating illustration rows ("expert rows") =====
 * A copy column beside an illustrated panel; every other row flips sides.
 * Shared by employers + hire + train. Tint the right panel with .sc-tint-*.
 * The .sc-* family inside the panel are content utilities (person card, mock UI). */
.experts-inner { max-width: var(--content-wide); margin: 0 auto; }  /* same inset as .section-narrow (1180) so the services grid lines up with reviews and every other content section — no bespoke width */
.experts-list { display: flex; flex-direction: column; gap: 80px; }
.expert-row { display: grid; grid-template-columns: 1fr 1fr; min-height: 360px; gap: 60px; align-items: stretch; }
/* alternate: flip the second row so copy and illustration swap sides */
.experts-list .expert-row:nth-child(2) .sc-right { grid-column: 1; grid-row: 1; }
.experts-list .expert-row:nth-child(2) .sc-left  { grid-column: 2; grid-row: 1; padding: 4rem 60px 4rem 40px; }
